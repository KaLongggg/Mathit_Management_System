# wa-stack environment — copy to ".env" on the server and fill in real values.
# The real .env lives ONLY on the VPS at /root/wa-stack/.env — never commit it.

# Shared secret between scheduler and bot (sent as the X-API-KEY header)
BOT_SHARED_SECRET=change-me

# true = log intended sends without actually sending (dry run)
DRY_RUN=false

# Bot send endpoint — scheduler -> bot over the compose network.
# Default/fallback when a schedule has no bot_id (single-bot back-compat).
WA_API_URL=http://bot:3000/send

# Multi-account routing: maps each schedule's bot_id -> that bot's base URL.
# The scheduler appends /send. Unknown/null bot_id falls back to WA_API_URL.
BOT_ENDPOINTS={"whatsapp_bot":"http://bot:3000","whatsapp_bot_2":"http://bot2:3000"}

# Supabase Postgres connection (used by the bot heartbeat + scheduler queries)
user=postgres.xxxxxxxx
password=change-me
host=aws-0-xxx.pooler.supabase.com
port=5432
dbname=postgres

# Optional tuning (defaults shown)
# LOG_LEVEL=INFO
# DB_CONNECT_TIMEOUT=10
# DB_STATEMENT_TIMEOUT_MS=20000
# HTTP_TIMEOUT=20
